PORT=3000
DATABASE_URL=postgresql://jptaxi_app:change_me@localhost:5432/JPTaxi
DATABASE_ADMIN_URL=postgresql://postgres:change_me@localhost:5432/postgres
DB_SSL=false
DB_POOL_MAX=3
DB_POOL_MIN=1
DB_CONNECTION_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=600000
DB_MAX_LIFETIME_MS=1800000
JWT_SECRET=replace_with_at_least_32_random_characters
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGIN_PATTERNS=https://*.vercel.app
RESET_PASSWORD_URL=http://localhost:5173/reset-password
PASSWORD_RESET_EXPIRATION_MINUTES=30
AUTO_APPROVE_DRIVERS=false

UPLOAD_MODE=local
UPLOAD_PUBLIC_BASE_URL=http://localhost:3000
UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_MAX_REQUEST_SIZE_MB=40
# Spring-compatible aliases below take precedence when present:
# SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
# SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=40MB
# SUPABASE_STORAGE_ENDPOINT=
# SUPABASE_STORAGE_REGION=
# SUPABASE_STORAGE_ACCESS_KEY=
# SUPABASE_STORAGE_SECRET_KEY=
# SUPABASE_STORAGE_BUCKET=
# SUPABASE_STORAGE_PUBLIC_URL=
# If UPLOAD_MODE is omitted and all SUPABASE_STORAGE_* values are present,
# the app will automatically use supabase_s3.

MAIL_MODE=console
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=JP Taxi <noreply@luongvanhungnet.xyz>
# RESEND_API_KEY=
# RESEND_API_URL=https://api.resend.com/emails
# RESEND_CONNECT_TIMEOUT_MS=10000
# RESEND_READ_TIMEOUT_MS=15000
# MAIL_FROM=JP Taxi <noreply@luongvanhungnet.xyz>
# Spring-compatible aliases below take precedence when present:
# RESEND_CONNECT_TIMEOUT=10s
# RESEND_READ_TIMEOUT=15s
# APP_MAIL_FROM=JP Taxi <noreply@luongvanhungnet.xyz>
# If MAIL_MODE is omitted, the app auto-selects:
# resend when RESEND_API_KEY exists, smtp when SMTP_HOST/SMTP_USER/SMTP_PASS exist,
# otherwise console.

NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OSRM_BASE_URL=https://router.project-osrm.org

DISPATCH_SCHEDULER_ENABLED=true
DISPATCH_INITIAL_RADIUS_KM=2
DISPATCH_RADIUS_STEP_KM=1
DISPATCH_EXPANSION_INTERVAL_MS=2000
DISPATCH_OFFER_TIMEOUT_MS=30000
DISPATCH_LOCATION_MAX_AGE_MINUTES=30
DISPATCH_SEARCH_STALE_MINUTES=2
